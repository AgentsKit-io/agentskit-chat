{
  "schemaVersion": 1,
  "project": {
    "name": "agentskit-chat"
  },
  "corpus": {
    "agent": {
      "root": "docs/for-agents",
      "index": "docs/for-agents/index.md",
      "include": [
        "**/*.md"
      ],
      "exclude": [
        "**/node_modules/**"
      ]
    },
    "human": {
      "plugin": "plain-markdown",
      "options": {
        "contentDir": "docs",
        "include": [
          "**/*.md"
        ],
        "urlPrefix": null
      }
    }
  },
  "routing": {
    "options": {
      "ownership": {
        "product": {
          "path": "docs/product",
          "purpose": "Product requirements, user stories, scope, and release outcomes",
          "agentDoc": "docs/for-agents/product.md",
          "humanDoc": "product/PRD",
          "checks": [
            "pnpm docs:bridge:gate"
          ]
        },
        "architecture": {
          "path": "docs/architecture",
          "purpose": "System boundaries, protocols, modules, ADRs, and cross-framework invariants",
          "agentDoc": "docs/for-agents/architecture.md",
          "humanDoc": "architecture/overview",
          "checks": [
            "pnpm docs:bridge:gate"
          ]
        },
        "governance": {
          "path": ".github",
          "purpose": "Issue structure, Definition of Done, contribution workflow, and project automation",
          "agentDoc": "docs/for-agents/governance.md",
          "humanDoc": "governance/issues",
          "checks": [
            "pnpm docs:bridge:gate"
          ]
        },
        "alpha-release": {
          "path": "docs/releases",
          "purpose": "Immutable public prerelease artifacts for external dogfood hosts",
          "agentDoc": "docs/for-agents/governance.md",
          "humanDoc": "releases/alpha-dogfood",
          "checks": [
            "pnpm lint",
            "pnpm test",
            "pnpm build",
            "pnpm docs:bridge:gate"
          ]
        },
        "release": {
          "path": "release",
          "purpose": "Fixed public package graph, stable documentation, provenance, clean-install gates, and HITL publication",
          "agentDoc": "docs/for-agents/release.md",
          "humanDoc": "releases/release-process",
          "checks": [
            "pnpm lint",
            "pnpm test",
            "pnpm build",
            "pnpm conformance:gate",
            "pnpm docs:bridge:gate",
            "pnpm release:gate",
            "pnpm release:pack"
          ]
        },
        "dogfood-hosts": {
          "path": "docs/dogfood",
          "purpose": "External live-host migrations, ownership corrections, parity, and no-reimplementation evidence",
          "agentDoc": "docs/for-agents/architecture.md",
          "humanDoc": "dogfood/registry-playbook",
          "checks": [
            "pnpm lint",
            "pnpm test",
            "pnpm build",
            "pnpm docs:bridge:gate"
          ]
        },
        "docs-app": {
          "path": "apps/docs",
          "purpose": "Fumadocs portal and full public framework dogfood over the canonical docs corpus",
          "agentDoc": "docs/for-agents/apps/docs.md",
          "humanDoc": "architecture/adrs/0027-fumadocs-framework-dogfood",
          "checks": [
            "pnpm --filter @agentskit/chat-docs lint",
            "pnpm --filter @agentskit/chat-docs test",
            "pnpm --filter @agentskit/chat-docs build",
            "pnpm --filter @agentskit/chat-docs test:e2e",
            "pnpm docs:bridge:gate"
          ]
        },
        "chat": {
          "path": "packages/chat",
          "purpose": "Framework-neutral chat application definitions composed around AgentsKit ChatConfig",
          "agentDoc": "docs/for-agents/packages/chat.md",
          "humanDoc": "getting-started/react",
          "checks": [
            "pnpm --filter @agentskit/chat lint",
            "pnpm --filter @agentskit/chat test"
          ]
        },
        "protocol": {
          "path": "packages/protocol",
          "purpose": "Versioned turn events, runtime schemas, typed diagnostics, compatibility, and shared fixtures",
          "agentDoc": "docs/for-agents/packages/protocol.md",
          "humanDoc": "protocol/v1",
          "checks": [
            "pnpm --filter @agentskit/chat-protocol lint",
            "pnpm --filter @agentskit/chat-protocol test"
          ]
        },
        "react": {
          "path": "packages/react",
          "purpose": "React application shell consuming @agentskit/react directly",
          "agentDoc": "docs/for-agents/packages/react.md",
          "humanDoc": "getting-started/react",
          "checks": [
            "pnpm --filter @agentskit/chat-react lint",
            "pnpm --filter @agentskit/chat-react test"
          ]
        },
        "vue": {
          "path": "packages/vue",
          "purpose": "Vue application shell consuming @agentskit/vue directly",
          "agentDoc": "docs/for-agents/packages/vue.md",
          "humanDoc": "getting-started/vue",
          "checks": [
            "pnpm --filter @agentskit/chat-vue lint",
            "pnpm --filter @agentskit/chat-vue test"
          ]
        },
        "svelte": {
          "path": "packages/svelte",
          "purpose": "Svelte 5 application shell consuming @agentskit/svelte directly",
          "agentDoc": "docs/for-agents/packages/svelte.md",
          "humanDoc": "getting-started/svelte",
          "checks": ["pnpm --filter @agentskit/chat-svelte lint", "pnpm --filter @agentskit/chat-svelte test"]
        },
        "solid": {
          "path": "packages/solid",
          "purpose": "Solid application shell consuming @agentskit/solid directly",
          "agentDoc": "docs/for-agents/packages/solid.md",
          "humanDoc": "getting-started/solid",
          "checks": ["pnpm --filter @agentskit/chat-solid lint", "pnpm --filter @agentskit/chat-solid test"]
        },
        "angular": {
          "path": "packages/angular",
          "purpose": "Standalone Angular application shell consuming @agentskit/angular directly",
          "agentDoc": "docs/for-agents/packages/angular.md",
          "humanDoc": "getting-started/angular",
          "checks": ["pnpm --filter @agentskit/chat-angular lint", "pnpm --filter @agentskit/chat-angular test"]
        },
        "react-native": {
          "path": "packages/react-native",
          "purpose": "React Native application shell consuming @agentskit/react-native directly",
          "agentDoc": "docs/for-agents/packages/react-native.md",
          "humanDoc": "getting-started/react-native",
          "checks": [
            "pnpm --filter @agentskit/chat-react-native lint",
            "pnpm --filter @agentskit/chat-react-native test"
          ]
        },
        "ink": {
          "path": "packages/ink",
          "purpose": "Ink application shell consuming @agentskit/ink directly with semantic text fallback",
          "agentDoc": "docs/for-agents/packages/ink.md",
          "humanDoc": "getting-started/ink",
          "checks": [
            "pnpm --filter @agentskit/chat-ink lint",
            "pnpm --filter @agentskit/chat-ink test"
          ]
        },
        "cli": {
          "path": "packages/cli",
          "purpose": "Safe seven-renderer application and semantic-component scaffolding",
          "agentDoc": "docs/for-agents/packages/cli.md",
          "humanDoc": "cli",
          "checks": [
            "pnpm --filter @agentskit/chat-cli lint",
            "pnpm --filter @agentskit/chat-cli test"
          ]
        },
        "devtools": {
          "path": "packages/devtools",
          "purpose": "Replayable application traces and semantic renderer parity composed with AgentsKit eval",
          "agentDoc": "docs/for-agents/packages/devtools.md",
          "humanDoc": "devtools",
          "checks": [
            "pnpm --filter @agentskit/chat-devtools lint",
            "pnpm --filter @agentskit/chat-devtools test"
          ]
        },
        "example-react": {
          "path": "apps/example-react",
          "purpose": "React surface of support, onboarding, and protected operations references",
          "agentDoc": "docs/for-agents/apps/example-react.md",
          "humanDoc": "examples/support-reference",
          "checks": [
            "pnpm --filter @agentskit/chat-example-react build",
            "pnpm test:e2e --project=react"
          ]
        },
        "example-vue": {
          "path": "apps/example-vue",
          "purpose": "Vue surface of shared support, onboarding, operations, and RAG references",
          "agentDoc": "docs/for-agents/apps/example-vue.md",
          "humanDoc": "examples/dom-renderer-parity",
          "checks": [
            "pnpm --filter @agentskit/chat-example-vue build",
            "pnpm test:e2e --project=vue"
          ]
        },
        "example-svelte": {
          "path": "apps/example-svelte",
          "purpose": "Svelte 5 surface of shared support, onboarding, operations, and RAG references",
          "agentDoc": "docs/for-agents/apps/example-svelte.md",
          "humanDoc": "examples/dom-renderer-parity",
          "checks": [
            "pnpm --filter @agentskit/chat-example-svelte build"
          ]
        },
        "example-solid": {
          "path": "apps/example-solid",
          "purpose": "Solid surface of shared support, onboarding, operations, and RAG references",
          "agentDoc": "docs/for-agents/apps/example-solid.md",
          "humanDoc": "examples/dom-renderer-parity",
          "checks": [
            "pnpm --filter @agentskit/chat-example-solid build"
          ]
        },
        "example-shared": {
          "path": "apps/example-shared",
          "purpose": "Framework-neutral support, onboarding, and protected operations domains with injected host seams",
          "agentDoc": "docs/for-agents/apps/example-shared.md",
          "humanDoc": "examples/support-reference",
          "checks": [
            "pnpm lint",
            "pnpm test"
          ]
        },
        "example-react-native": {
          "path": "apps/example-react-native",
          "purpose": "Expo proof of support, onboarding, and protected operations parity",
          "agentDoc": "docs/for-agents/apps/example-react-native.md",
          "humanDoc": "examples/support-reference",
          "checks": [
            "pnpm --filter @agentskit/chat-example-react-native build",
            "pnpm test:e2e --project=react-native"
          ]
        },
        "example-ink": {
          "path": "apps/example-ink",
          "purpose": "Executable PTY proof of support, onboarding, and protected operations parity",
          "agentDoc": "docs/for-agents/apps/example-ink.md",
          "humanDoc": "examples/support-reference",
          "checks": [
            "pnpm --filter @agentskit/chat-example-ink build",
            "pnpm test:pty"
          ]
        },

        "operations-reference": {
          "path": "apps/example-shared",
          "purpose": "Policy-protected operations domain, audit trace, and deployment recipe",
          "agentDoc": "docs/for-agents/apps/example-shared.md",
          "humanDoc": "examples/operations-reference",
          "checks": [
            "pnpm --filter @agentskit/chat-example-shared test",
            "pnpm docs:bridge:gate"
          ]
        },
        "rag-reference": {
          "path": "apps/example-shared",
          "purpose": "Provider-agnostic cited RAG application and SourceList projection recipe",
          "agentDoc": "docs/for-agents/apps/example-shared.md",
          "humanDoc": "examples/rag-reference",
          "checks": [
            "pnpm --filter @agentskit/chat-example-shared test",
            "pnpm test:e2e"
          ]
        }
      }
    }
  },
  "index": {
    "outFile": ".doc-bridge/index.json",
    "llmsTxt": {
      "enabled": true,
      "outFile": ".doc-bridge/llms.txt",
      "preamble": "AgentsKit Chat is the cross-framework application framework for interactive agent experiences built on AgentsKit."
    },
    "capabilities": {
      "enabled": true,
      "outFile": ".doc-bridge/capabilities.json"
    }
  },
  "gates": {
    "preset": "standard",
    "include": [
      "documentation-standard-v1"
    ],
    "exclude": [
      "okf-type"
    ]
  },
  "conformance": {
    "documentationStandardV1": {
      "rawSources": [
        "README.md",
        "docs/index.mdx",
        "docs/for-agents/index.md"
      ],
      "contributionPaths": [
        "CONTRIBUTING.md"
      ],
      "metadata": [
        {
          "path": "apps/docs/app/layout.tsx",
          "contains": [
            "export const metadata",
            "title:",
            "description:",
            "openGraph:"
          ]
        }
      ],
      "links": [
        {
          "url": "https://www.agentskit.io/docs",
          "paths": ["docs/index.mdx"]
        },
        {
          "url": "https://registry.agentskit.io",
          "paths": ["README.md", "docs/index.mdx"]
        },
        {
          "url": "https://playbook.agentskit.io/docs",
          "paths": ["docs/index.mdx"]
        },
        {
          "url": "https://agentskit-io.github.io/doc-bridge/",
          "paths": ["README.md", "docs/index.mdx"]
        },
        {
          "url": "https://github.com/AgentsKit-io/code-review-cli#readme",
          "paths": ["README.md", "docs/index.mdx"]
        },
        {
          "url": "https://akos.agentskit.io/docs",
          "paths": ["docs/index.mdx"]
        }
      ],
      "ecosystemContract": {
        "manifest": "ecosystem.json",
        "claims": "ecosystem-contract-claims.json",
        "productId": "agentskit-chat"
      },
      "quickstarts": [
        {
          "id": "react-chat",
          "doc": "docs/getting-started/react.md",
          "test": "tests/e2e/chat-conformance.ts",
          "command": "pnpm test:e2e --project=react",
          "testContains": [
            "streams a deterministic answer",
            "AgentsKit received: hello"
          ]
        }
      ],
      "visuals": [
        "docs/assets/agentschat-architecture.svg"
      ],
      "diagrams": [
        {
          "path": "docs/backend.md",
          "contains": ["```mermaid"]
        }
      ]
    }
  },
  "surfaces": {
    "cli": {
      "bin": "ak-docs",
      "defaultFormat": "json"
    },
    "mcp": {
      "enabled": true,
      "tools": [
        "handoff.resolve",
        "doc.search",
        "doc.get",
        "gate.status",
        "memory.classify",
        "memory.promoteDraft",
        "retriever.query"
      ]
    }
  },
  "intelligence": {
    "enabled": true,
    "adapter": {
      "provider": "ollama",
      "model": "llama3.2",
      "apiKeyEnv": ""
    },
    "chat": {
      "enabled": true,
      "sources": ["agent", "human", "federation"],
      "handoffFirst": true
    },
    "retriever": {
      "enabled": true,
      "mode": "agentskit-rag"
    },
    "memory": {
      "enabled": true,
      "adapters": ["playbook-memory", "cursor-rules", "session-export"],
      "ingestDir": ".doc-bridge/memory-inbox",
      "classify": true,
      "promote": {
        "enabled": true,
        "targets": ["agent", "human", "agents-md"],
        "requireApproval": true
      }
    },
    "runtime": "agentskit"
  },
  "federation": {
    "enabled": true,
    "sources": [
      {
        "id": "agentskit",
        "llmsTxt": "https://www.agentskit.io/llms.txt",
        "includeInRetriever": true,
        "includeInChat": true
      },
      {
        "id": "playbook",
        "llmsTxt": "https://playbook.agentskit.io/llms.txt",
        "rawBaseUrl": "https://playbook.agentskit.io/raw/",
        "includeInRetriever": true,
        "includeInChat": true
      },
      {
        "id": "registry",
        "llmsTxt": "https://registry.agentskit.io/llms.txt",
        "includeInRetriever": false,
        "includeInChat": true
      }
    ]
  }
}
