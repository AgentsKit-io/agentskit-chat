{
  "name": "@agentskit/chat",
  "version": "0.1.0-alpha.2",
  "description": "Cross-framework application definitions for AgentsKit Chat.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "lint": "tsc --noEmit",
    "test": "pnpm --filter @agentskit/chat-protocol build && vitest run"
  },
  "peerDependencies": {
    "@agentskit/core": "^1.12.3"
  },
  "dependencies": {
    "@agentskit/chat-protocol": "workspace:*",
    "@agentskit/memory": "^0.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@agentskit/core": "^1.12.3",
    "tsup": "^8.5.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
