{
  "name": "@agentskit/chat",
  "version": "0.4.0",
  "description": "Cross-framework application definitions for AgentsKit Chat.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AgentsKit-io/agentskit-chat.git",
    "directory": "packages/chat"
  },
  "homepage": "https://github.com/AgentsKit-io/agentskit-chat#readme",
  "bugs": {
    "url": "https://github.com/AgentsKit-io/agentskit-chat/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./protocol": {
      "types": "./dist/protocol.d.ts",
      "import": "./dist/protocol.js",
      "require": "./dist/protocol.cjs"
    },
    "./protocol/fixtures": {
      "types": "./dist/protocol-fixtures.d.ts",
      "import": "./dist/protocol-fixtures.js",
      "require": "./dist/protocol-fixtures.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./devtools": {
      "types": "./dist/devtools.d.ts",
      "import": "./dist/devtools.js",
      "require": "./dist/devtools.cjs"
    },
    "./react": {
      "types": "./dist/renderers/react/index.d.ts",
      "import": "./dist/renderers/react/index.js",
      "require": "./dist/renderers/react/index.cjs"
    },
    "./react-native": {
      "types": "./dist/renderers/react-native/index.d.ts",
      "import": "./dist/renderers/react-native/index.js",
      "require": "./dist/renderers/react-native/index.cjs"
    },
    "./ink": {
      "types": "./dist/renderers/ink/index.d.ts",
      "import": "./dist/renderers/ink/index.js"
    },
    "./vue": {
      "types": "./dist/renderers/vue/index.d.ts",
      "import": "./dist/renderers/vue/index.js",
      "require": "./dist/renderers/vue/index.cjs"
    },
    "./solid": {
      "types": "./dist/renderers/solid/index.d.ts",
      "import": "./dist/renderers/solid/index.js",
      "require": "./dist/renderers/solid/index.cjs"
    },
    "./svelte": {
      "types": "./dist/renderers/svelte/index.d.ts",
      "svelte": "./dist/renderers/svelte/index.js",
      "import": "./dist/renderers/svelte/index.js"
    },
    "./angular": {
      "types": "./dist/renderers/angular/types/agentskit-chat-angular.d.ts",
      "import": "./dist/renderers/angular/fesm2022/agentskit-chat-angular.mjs",
      "default": "./dist/renderers/angular/fesm2022/agentskit-chat-angular.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "tsc --noEmit",
    "test": "pnpm --filter @agentskit/chat-protocol build && vitest run"
  },
  "peerDependencies": {
    "@agentskit/core": "^1.12.3",
    "@agentskit/angular": "^0.4.6",
    "@agentskit/ink": "^0.10.1",
    "@agentskit/react": "^0.7.1",
    "@agentskit/react-native": "^0.4.4",
    "@agentskit/solid": "^0.4.4",
    "@agentskit/svelte": "^0.4.4",
    "@agentskit/vue": "^0.4.4",
    "@angular/common": ">=18.1 <22",
    "@angular/core": ">=18.1 <22",
    "ink": ">=7.1.0",
    "react": ">=18",
    "react-native": "*",
    "rxjs": "^7.0.0",
    "solid-js": "^1.9.0",
    "svelte": "^5.0.0",
    "vue": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "@agentskit/angular": {
      "optional": true
    },
    "@agentskit/ink": {
      "optional": true
    },
    "@agentskit/react": {
      "optional": true
    },
    "@agentskit/react-native": {
      "optional": true
    },
    "@agentskit/solid": {
      "optional": true
    },
    "@agentskit/svelte": {
      "optional": true
    },
    "@agentskit/vue": {
      "optional": true
    },
    "@angular/common": {
      "optional": true
    },
    "@angular/core": {
      "optional": true
    },
    "ink": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "rxjs": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "dependencies": {
    "@agentskit/eval": "^0.4.17",
    "@agentskit/memory": "^0.11.0",
    "@agentskit/statechart": "^0.2.0",
    "zod": "^4.3.6",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@agentskit/core": "^1.12.3",
    "@agentskit/chat-protocol": "workspace:*",
    "@types/node": "^25.0.0",
    "tsup": "^8.5.1"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
