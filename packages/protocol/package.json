{
  "name": "@agentskit/chat-protocol",
  "version": "0.1.0",
  "description": "Versioned turn protocol for AgentsKit Chat.",
  "license": "MIT",
  "repository": { "type": "git", "url": "git+https://github.com/AgentsKit-io/agentskit-chat.git", "directory": "packages/protocol" },
  "homepage": "https://github.com/AgentsKit-io/agentskit-chat#readme",
  "bugs": { "url": "https://github.com/AgentsKit-io/agentskit-chat/issues" },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./fixtures": {
      "types": "./dist/fixtures.d.ts",
      "import": "./dist/fixtures.js",
      "require": "./dist/fixtures.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/fixtures.ts --format esm,cjs --dts --clean",
    "lint": "tsc --noEmit",
    "test": "vitest run --coverage"
  },
  "peerDependencies": {
    "@agentskit/core": "^1.12.1"
  },
  "dependencies": {
    "@noble/hashes": "2.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@agentskit/core": "^1.12.2",
    "tsup": "^8.5.1"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
