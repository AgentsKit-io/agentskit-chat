{
  "name": "@agentskit/chat-react-native",
  "version": "0.0.0",
  "description": "React Native renderer for AgentsKit Chat.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js", "require": "./dist/index.cjs" } },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.tsx --format esm,cjs --dts --clean --external react --external react-native --external @agentskit/react-native",
    "lint": "tsc --noEmit",
    "test": "vitest run --environment happy-dom"
  },
  "dependencies": { "@agentskit/chat": "workspace:*" },
  "peerDependencies": {
    "@agentskit/react-native": "^0.3.4",
    "react": ">=18",
    "react-native": "*"
  },
  "devDependencies": {
    "@agentskit/core": "^1.10.1",
    "@agentskit/react-native": "^0.3.4",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "happy-dom": "^20.10.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-native": "^0.86.0",
    "tsup": "^8.5.1"
  }
}
